# --- Azure OpenAI (default chat client for all patterns) ---
# Endpoint of your Azure OpenAI resource, e.g. https://my-aoai.openai.azure.com
AZURE_OPENAI_ENDPOINT=
# The *deployment name* of the chat model (NOT the model name). e.g. gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT=
# Pin to a stable API version
AZURE_OPENAI_API_VERSION=2024-10-21

# Auth: by default we use AzureCliCredential (run `az login` once).
# If you'd rather use an API key, uncomment and fill:
# AZURE_OPENAI_API_KEY=

# --- Pattern 0: PR Triager ---
# A GitHub token with `repo` scope (classic PAT or fine-grained) to read PR data.
# Without it you'll be rate-limited and won't be able to read private repos.
GITHUB_TOKEN=
